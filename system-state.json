  "patterns": {
    "pattern_a": {
      "id": "Pattern A",
      "name": "Pulse Review Pattern",
      "description": "Standardized daily operational health check where role leaders review role-specific metrics dashboards against configured thresholds and log alerts for investigation.",
      "status": "not_started",
      "shortcutSummary": "/daily-pulse, /paid-media-pulse, /amazon-pulse, /project-pulse",
      "steps": [
        {
          "step": 1,
          "action": "Receive refreshed data mart(s) after daily dbt run completes (typically 6:00-6:30 AM UTC)",
          "actor": "Data Intelligence Lead (system)"
        },
        {
          "step": 2,
          "action": "Review role-specific metrics panel against configured thresholds",
          "actor": "Role Leader (manual review)"
        },
        {
          "step": 3,
          "action": "Flag items exceeding threshold as alerts: RED (immediate escalation) or YELLOW (monitor trend)",
          "actor": "Role Leader (categorization)"
        },
        {
          "step": 4,
          "action": "Log flags as tasks (own-role action) or escalations (cross-role impact) with full context",
          "actor": "Role Leader (logging)"
        },
        {
          "step": 5,
          "action": "If cross-role impact detected, route alert to relevant role owner with context",
          "actor": "Role Leader (escalation routing)"
        }
      ],
      "usedBy": [
        {
          "role": "Chief Growth Officer",
          "processes": [
            {
              "id": "1.1",
