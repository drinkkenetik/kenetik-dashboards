    "pattern_b": {
      "id": "Pattern B",
      "name": "Brief Request Pattern",
      "description": "Standardized process for any role that needs creative assets to submit requests to Creative Strategist (4a.3) instead of generating full Creative Brief Objects themselves.",
      "status": "not_started",
      "shortcutSummary": "/creative-brief routes to Creative Strategist 4a.3",
      "steps": [
        {
          "step": 1,
          "action": "Identify creative need: source signal (gap, opportunity, risk mitigation) and business context",
          "actor": "Requesting Role"
        },
        {
          "step": 2,
          "action": "Determine priority: Urgent (<48h), Standard (7-14 days), Backlog (no firm deadline)",
          "actor": "Requesting Role"
        },
        {
          "step": 3,
          "action": "Populate brief request schema: source_signal, priority, objective, surface, segment, product_type, offer, claim_tier",
          "actor": "Requesting Role"
        },
        {
          "step": 4,
          "action": "Submit request to Creative Strategist (4a.3) via /creative-brief shortcut",
          "actor": "Requesting Role"
        },
        {
          "step": 5,
          "action": "Creative Strategist receives, validates demand signal, populates complete Creative Brief Object",
          "actor": "Creative Strategist (4a.3)"
        },
        {
          "step": 6,
          "action": "Creative Strategist routes to Content Producer (4b), manages quality gates and SLA tracking",
          "actor": "Creative Strategist (4a.3)"
        },
        {
          "step": 7,
          "action": "When asset delivered, requesting role deploys through its own workflow",
          "actor": "Requesting Role"
        }
      ],
      "usedBy": [
        {
          "role": "Operations Intelligence Lead",
          "processes": [
            {
              "id": "3.3",
              "name": "ChangeSet Recommendation Generation"
            }
          ]
        },
        {
          "role": "Web & Experimentation Lead",
          "processes": [
            {
              "id": "6.8",
              "name": "Creative Brief Generation for Web Content"
            }
          ]
        },
        {
          "role": "Channel Execution Manager",
          "processes": [
            {
              "id": "7.7",
              "name": "Creative Sourcing & ChangeSet Integration"
            }
          ]
        },
        {
          "role": "Paid Media Manager",
          "processes": [
            {
              "id": "8.4",
              "name": "Creative Freshness Pre-Condition"
            }
          ]
        }
      ]
    },
    "pattern_c": {
      "id": "Pattern C",
      "name": "Learning Record Pattern",
      "description": "Standardized process for roles that generate learning insights to submit learning records to System Learning Protocol (3.8) instead of independently pushing to skill files or learning libraries.",
      "status": "not_started",
      "shortcutSummary": "/learning-record submits to System Learning Protocol 3.8",
      "steps": [
        {
          "step": 1,
          "action": "Identify learning threshold: 5+ data points, >30% outperformance, >80% confidence, actionable insight",
          "actor": "Process Owner"
        },
        {
          "step": 2,
          "action": "Produce standardized learning record: what changed, outcome data, context, what we'd do differently",
          "actor": "Process Owner"
        },
        {
          "step": 3,
          "action": "Include supporting evidence: performance data links, A/B results, competitor/historical benchmarks",
          "actor": "Process Owner"
        },
        {
          "step": 4,
          "action": "Submit learning record to System Learning Protocol (3.8) via /learning-record shortcut",
          "actor": "Process Owner"
        },
        {
          "step": 5,
          "action": "Protocol 3.8 receives record, evaluates confidence level and impact scope",
          "actor": "Ops Intelligence (3.8)"
        },
        {
          "step": 6,
          "action": "Protocol 3.8 routes: to Performance Memory, skill file queue, learning notes library, or validation queue",
          "actor": "Ops Intelligence (3.8)"
        },
        {
          "step": 7,
          "action": "Protocol 3.8 gates all routing decisions, ensuring consistent standards",
          "actor": "Ops Intelligence (3.8)"
        }
      ],
      "usedBy": [
        {
          "role": "Content Producer (Larry 2.0)",
