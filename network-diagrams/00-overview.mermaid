---
title: "Kenetik Growth System — Network Overview"
---
flowchart TB
    %% ============================================================
    %% EXTERNAL & INTEGRATION
    %% ============================================================

    EXT(["🔌 External Sources<br/><i>17 data feeds</i>"])
    INT(["⚡ Integration Layer<br/><i>7 MCPs + 3 Platforms</i>"])

    %% ============================================================
    %% TIER 1: INTELLIGENCE
    %% ============================================================

    subgraph T1["Intelligence Layer"]
        direction LR
        DIL["📊 DIL — Peter<br/>Data Intelligence<br/><i>10 processes</i>"]
        OIL["⚙️ OIL — Claude<br/>Operations Intelligence<br/><i>9 processes</i>"]
    end

    %% ============================================================
    %% TIER 2: EXECUTIVE
    %% ============================================================

    CGO["👑 CGO — Devon<br/>Chief Growth Officer<br/><i>5 processes</i>"]

    %% ============================================================
    %% TIER 3: STRATEGY & PLANNING
    %% ============================================================

    subgraph T3["Strategy & Creative"]
        direction LR
        MSIL["📅 MSIL — Katie<br/>Marketing & Social Intel<br/><i>9 processes</i>"]
        CS["🎨 CS — Moe<br/>Creative Strategist<br/><i>9 processes</i>"]
        LARRY["✍️ Larry<br/>Content Producer<br/><i>6 processes</i>"]
    end

    %% ============================================================
    %% TIER 4: EXECUTION
    %% ============================================================

    subgraph T4["Execution Layer"]
        direction LR
        WEL["🌐 WEL — Brandon<br/>Web & Experimentation<br/><i>9 processes</i>"]
        CEM["📢 CEM — Olivia<br/>Channel Execution<br/><i>9 processes</i>"]
        PMM["💰 PMM — Jake<br/>Paid Media<br/><i>7 processes</i>"]
        AMM["📦 AMM — Marcus<br/>Amazon Marketplace<br/><i>7 processes</i>"]
    end

    %% ============================================================
    %% TIER 5: INFRASTRUCTURE
    %% ============================================================

    PM["🏗️ PM — Claude<br/>Project Manager<br/><i>6 processes</i>"]

    %% ============================================================
    %% SHARED ARTIFACTS
    %% ============================================================

    subgraph ART["📦 Shared Artifacts"]
        direction LR
        A_CT[("ChangeSet<br/>Tracker")]
        A_ECL[("Edge Case<br/>Log")]
        A_LR[("Learning<br/>Record Log")]
        A_PM[("Performance<br/>Memory")]
        A_SF[("Skill<br/>Files")]
        A_SOC[("System Opt<br/>Config")]
        A_CL[("Claims<br/>Library")]
    end

    %% ============================================================
    %% CONNECTIONS: External → Intelligence
    %% ============================================================

    EXT --> INT
    INT --> DIL
    INT --> OIL

    %% ============================================================
    %% CONNECTIONS: Intelligence → Executive (hub-and-spoke pulse)
    %% ============================================================

    DIL -->|"Pulse reports,<br/>dashboards, NLQ"| CGO
    OIL -->|"Optimization status,<br/>edge case summaries"| CGO
    PMM -->|"Paid media<br/>pulse"| CGO
    AMM -->|"Amazon<br/>pulse"| CGO
    PM -->|"Health status,<br/>coordination"| CGO

    %% ============================================================
    %% CONNECTIONS: Intelligence → Strategy/Creative
    %% ============================================================

    DIL -->|"VoC, trends,<br/>funnel diagnosis"| CS
    DIL -->|"Trend signals"| MSIL
    OIL -->|"Guardrails,<br/>inventory alerts"| CS
    OIL -->|"Learning synthesis"| CS

    %% ============================================================
    %% CONNECTIONS: Intelligence → Execution
    %% ============================================================

    DIL -->|"Dashboards,<br/>attribution"| PMM
    DIL -->|"Funnel<br/>opportunities"| WEL
    OIL -->|"ChangeSet recs,<br/>margin defs"| CEM
    OIL -->|"Inventory<br/>alerts"| PMM

    %% ============================================================
    %% CONNECTIONS: Executive → downstream
    %% ============================================================

    CGO -->|"Approved ChangeSets,<br/>budget, experiments"| CEM
    CGO -->|"Budget<br/>allocation"| PMM
    CGO -->|"Approved<br/>experiments"| WEL
    CGO -->|"Updated<br/>guardrails"| OIL

    %% ============================================================
    %% CONNECTIONS: Strategy ↔ Creative
    %% ============================================================

    MSIL -->|"Calendar, campaigns,<br/>creator briefs"| CS
    MSIL -->|"Social calendar,<br/>creator pipeline"| LARRY
    CS -->|"Brief Objects,<br/>compliance, patterns"| LARRY
    LARRY -->|"Published content,<br/>performance data"| CS
    CS -->|"Content intel<br/>feedback"| MSIL

    %% ============================================================
    %% CONNECTIONS: Strategy/Creative → Execution
    %% ============================================================

    CS -->|"Graduation<br/>ChangeSets"| CEM
    CS -->|"Freshness alerts,<br/>performance data"| PMM
    CS -->|"Creative briefs<br/>for web"| WEL
    LARRY -->|"Founder content"| CEM
    MSIL -->|"Campaign<br/>ChangeSets"| CEM
    MSIL -->|"Creator content<br/>pipeline"| CEM

    %% ============================================================
    %% CONNECTIONS: Execution → cross-role
    %% ============================================================

    WEL -->|"Deployment signals,<br/>SEO pipeline"| CEM
    WEL -->|"Deployment<br/>tracking"| PM
    CEM -->|"Email/subscription<br/>dashboards"| DIL
    CEM -->|"Graduation<br/>to paid"| PMM
    CEM -->|"Partner listing<br/>packets"| AMM
    PMM -->|"Budget/optimization<br/>ChangeSets"| CEM
    AMM -->|"Listing audit<br/>claims check"| CS

    %% ============================================================
    %% CONNECTIONS: Learning loop → OIL 3.8
    %% ============================================================

    MSIL -->|"Learning notes"| OIL
    WEL -->|"Learning records"| OIL
    CEM -->|"Measurement<br/>outcomes"| OIL
    PMM -->|"Experiment<br/>results"| OIL
    CS -->|"Performance<br/>insights"| OIL
    LARRY -->|"Learning<br/>records"| OIL

    %% ============================================================
    %% CONNECTIONS: Shared artifacts
    %% ============================================================

    OIL --> A_CT
    OIL --> A_ECL
    OIL --> A_SF
    OIL --> A_LR
    OIL --> A_SOC
    CEM --> A_CT
    CS --> A_PM
    PMM --> A_PM
    CS --> A_CL
    PM --> A_CT

    %% ============================================================
    %% STYLING
    %% ============================================================

    classDef cgo fill:#78350f,stroke:#fbbf24,color:#fff
    classDef dil fill:#1e3a8a,stroke:#3b82f6,color:#fff
    classDef oil fill:#3730a3,stroke:#818cf8,color:#fff
    classDef cs fill:#9a3412,stroke:#fb923c,color:#fff
    classDef larry fill:#9a3412,stroke:#fb923c,color:#fff
    classDef msil fill:#166534,stroke:#4ade80,color:#fff
    classDef wel fill:#1f2937,stroke:#9ca3af,color:#fff
    classDef cem fill:#1f2937,stroke:#9ca3af,color:#fff
    classDef pmm fill:#1f2937,stroke:#9ca3af,color:#fff
    classDef amm fill:#1f2937,stroke:#9ca3af,color:#fff
    classDef pm fill:#44403c,stroke:#a8a29e,color:#fff
    classDef artifact fill:#374151,stroke:#d1d5db,color:#fff
    classDef ext fill:#0f172a,stroke:#475569,color:#94a3b8
    classDef integ fill:#1e293b,stroke:#64748b,color:#cbd5e1

    class CGO cgo
    class DIL dil
    class OIL oil
    class CS cs
    class LARRY larry
    class MSIL msil
    class WEL wel
    class CEM cem
    class PMM pmm
    class AMM amm
    class PM pm
    class A_CT,A_ECL,A_LR,A_PM,A_SF,A_SOC,A_CL artifact
    class EXT ext
    class INT integ
