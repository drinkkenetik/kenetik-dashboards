graph LR

    %% AMM PROCESSES
    subgraph sg_amm["Attribution & Measurement Manager"]
        p_9_1["9.1<br/>Daily Pulse & Morning "]
        p_9_2["9.2<br/>Listing Optimization &"]
        p_9_3["9.3<br/>Amazon Listing Audit"]
        p_9_4["9.4<br/>Search Intelligence & "]
        p_9_5["9.5<br/>Amazon Advertising Bud"]
