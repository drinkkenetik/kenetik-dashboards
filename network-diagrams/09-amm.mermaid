        p_9_7["9.7<br/>Amazon Competitive Int"]
        p_9_8["9.8<br/>[CONSOLIDATED into Pro"]
    end
    class sg_amm thisRole

    %% OUTGOING: External processes this role sends data to
    out_2_7["2.7<br/>VoC (Voice of Customer"]
    class out_2_7 dil
    out_3_2["3.2<br/>Daily Inventory Rebala"]
    class out_3_2 oil
    out_3_8["3.8<br/>System Learning Protoc"]
    class out_3_8 oil

    %% INTERNAL FLOWS
    p_9_7 --> p_9_3
    p_9_4 --> p_9_3
    p_9_3 --> p_9_2

    %% OUTGOING FLOWS
    p_9_6 --> out_2_7
    p_9_1 --> out_3_2
    p_9_3 --> out_3_8

