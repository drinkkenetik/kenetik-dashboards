    in_8_1["8.1<br/>Daily Paid Media Pulse"]
    class in_8_1 pmm
    in_8_2["8.2<br/>Unified Cross-Platform"]
    class in_8_2 pmm

    %% CGO PROCESSES
    subgraph sg_cgo["Chief Growth Officer"]
        p_1_1["1.1<br/>Morning Health Check &"]
        p_1_2["1.2<br/>Weekly Marketing Revie"]
        p_1_3["1.3<br/>Monthly Optimization C"]
        p_1_4["1.4<br/>Quarterly Strategic Re"]
        p_1_5["1.5<br/>Executive Copilot — Na"]
    end
    class sg_cgo thisRole

    %% OUTGOING: External processes this role sends data to
    out_4b_5["4b.5<br/>Founder & Team Content"]
    class out_4b_5 larry
    out_5_1["5.1<br/>Marketing Calendar Man"]
