    %% INCOMING FLOWS
    in_2_4 --> p_1_3
    in_5_5 --> p_1_4
    in_5_9 --> p_1_4
    in_8_1 --> p_1_1
    in_8_2 --> p_1_1

    %% OUTGOING FLOWS
    p_1_2 --> out_5_1

