graph LR

    %% INCOMING: External processes sending data to this role
    in_2_4["2.4<br/>Automated Intelligence"]
    class in_2_4 dil
    in_5_5["5.5<br/>Social Listening & Com"]
    class in_5_5 msil
    in_5_9["5.9<br/>Marketing Activity ROI"]
